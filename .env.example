# Neon Postgres — connection string from https://console.neon.tech
# En local apunta SIEMPRE a la rama `dev` de Neon, nunca a producción.
# La URL de producción vive en Vercel env; en local se guarda aparte como
# DATABASE_URL_PROD y usarla (migraciones de prod) es un acto deliberado:
#   DATABASE_URL=$DATABASE_URL_PROD pnpm db:migrate
DATABASE_URL=
DATABASE_URL_PROD=

# Better-Auth — generate secret: npx @better-auth/cli secret
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# S3 — almacenamiento privado de PDFs de factura (bucket en región UE)
S3_REGION=eu-west-3
S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Opcional: endpoint S3-compatible (Cloudflare R2, MinIO). Vacío = AWS S3.
S3_ENDPOINT=

# Resend — reminder sending (week 2). Sin esta clave, el envío usa transporte
# dry-run (loguea en vez de enviar). Con ella, envía de verdad automáticamente.
RESEND_API_KEY=
# Remitente de los recordatorios (interino, hasta verificación de dominio por
# usuario). Debe ser de un dominio verificado en Resend cuando envíes de verdad.
REMINDER_FROM_EMAIL=recordatorios@tudominio.com

# Stripe — subscription billing (week 3)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Vercel Cron — protects /api/cron endpoints
CRON_SECRET=
