# Neon Postgres — connection string from https://console.neon.tech
DATABASE_URL=

# Better-Auth — generate secret: npx @better-auth/cli secret
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# S3 — almacenamiento privado de PDFs de factura (bucket en región UE)
S3_REGION=eu-west-3
S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Opcional: endpoint S3-compatible (Cloudflare R2, MinIO). Vacío = AWS S3.
S3_ENDPOINT=

# Resend — reminder sending (week 2)
RESEND_API_KEY=

# Stripe — subscription billing (week 3)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Vercel Cron — protects /api/cron endpoints
CRON_SECRET=
